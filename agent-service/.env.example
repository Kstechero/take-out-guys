APP_NAME=takeout-agent-service
APP_ENV=local
LOG_LEVEL=INFO
SPRING_INTERNAL_BASE_URL=http://127.0.0.1:8080
SPRING_INTERNAL_AUTH_TOKEN=local-internal-token
AGENT_SERVICE_AUTH_TOKEN=local-agent-token
LLM_BASE_URL=http://ai.tunayoshi.top:8000/v1
LLM_API_KEY=replace-with-local-key
LLM_MODEL=qwen36
LLM_TEMPERATURE=0.2
LLM_TIMEOUT_SECONDS=120
LLM_MAX_TOKENS=2048
EMBEDDING_MODEL=text-embedding-3-small
RAG_ENABLED=true
RAG_AUTO_INDEX=true
RAG_KNOWLEDGE_DIR=../docs/agent-service/knowledge
RAG_INDEX_PATH=data/rag-index.json
RAG_EMBEDDING_DIMENSIONS=2048
RAG_TOP_K=4
RAG_MIN_SCORE=0.15
CONFIRMATION_STORE_PATH=data/confirmations.sqlite3
GRAPH_CHECKPOINT_PATH=data/graph-checkpoints.sqlite3
GRAPH_CHECKPOINT_POSTGRES_DSN=
CONFIRMATION_TTL_SECONDS=300
RATE_LIMIT_REQUESTS_PER_MINUTE=120
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_RESET_SECONDS=30

# Copy this file to .env before running docker compose.
# Use long random URL-safe values and never commit the resulting .env file.

# The full initialization SQL creates and selects the fixed sky_take_out database.
SKY_MYSQL_USER=sky
SKY_MYSQL_PASSWORD=replace-with-a-long-random-password
SKY_MYSQL_ROOT_PASSWORD=replace-with-a-different-root-password
AGENT_POSTGRES_PASSWORD=replace-with-a-long-url-safe-password

# Java -> Python and Python -> Java use different service secrets.
AGENT_SERVICE_AUTH_TOKEN=replace-with-a-long-random-service-token
AGENT_INTERNAL_AUTH_TOKEN=replace-with-a-different-internal-token

# Keep management writes disabled until the smoke tests and confirmation flow pass.
AGENT_INTERNAL_WRITES_ENABLED=false

LLM_BASE_URL=https://your-openai-compatible-provider.example/v1
LLM_API_KEY=replace-with-your-provider-key
LLM_MODEL=qwen36
RATE_LIMIT_REQUESTS_PER_MINUTE=120

# Optional for real WeChat login. Placeholder values allow non-login health checks.
SKY_WECHAT_APPID=your-wechat-appid
SKY_WECHAT_SECRET=your-wechat-secret
